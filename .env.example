# ==============================================================================
# PLATFORM BACKEND — .env TEMPLATE
# ==============================================================================
# Bu FAQAT namuna (template). Serverda haqiqiy qiymatlar bilan `.env` yarating.
# PROD-KRITIK kalitlar "# [PROD]" bilan belgilangan — deployda majburiy to'g'rilang.
# Dev uchun: APP_ENV=local, APP_DEBUG=true, localhost URL'lari maqbul.
# ==============================================================================

APP_NAME="Digital Xorazm"
APP_ENV=production                       # [PROD] local emas — production
APP_KEY=                                 # [PROD] `php artisan key:generate` bilan yarating (bo'sh QOLMASIN)
APP_DEBUG=false                          # [PROD] prod'da HAR DOIM false (stack-trace + DB parol oshkoraligi)
APP_URL=https://api.digital-xorazm.uz    # [PROD] real API domeni — absolut rasm/asset URL'lari uchun

APP_LOCALE=uz
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=uz_UZ

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# Log
# ------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily                          # [PROD] single emas — kunlik fayllar (aylanish)
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                        # [PROD] debug emas — warning va yuqori

# ------------------------------------------------------------------------------
# Database (PostgreSQL) — sqlite EMAS
# ------------------------------------------------------------------------------
DB_CONNECTION=pgsql                      # [PROD] pgsql (sqlite dev artefakti — ishlatmang)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=xorazm                       # [PROD] boshqa app'lar bilan BO'LINMAGAN, alohida bo'sh DB
DB_USERNAME=xorazm
DB_PASSWORD=                             # [PROD] kuchli parol
DB_SSLMODE=prefer                        # [PROD] TLS bo'lsa: require
DB_CHARSET=utf8

# Har domen o'z PostgreSQL schema'sida — search_path (config/database.php).
# Schema'lar deployda yaratiladi: CREATE SCHEMA auth; master; mahalla; platform; ...
DB_SEARCH_PATH=public                    # default connection
DB_AUTH_SEARCH_PATH=auth,public          # markaziy identifikatsiya (auth.users, auth.sessions)
DB_MASTER_SEARCH_PATH=master,public      # geo (viloyat/tuman/mahalla reyestri)
DB_MAHALLA_SEARCH_PATH=mahalla,master,public
DB_HR_SEARCH_PATH=public,master          # HR/KBT (xodimlar, bo'limlar, rollar, audit)

# ------------------------------------------------------------------------------
# Session (Sanctum SPA — sessiya-asosli auth)
# ------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_CONNECTION=auth                  # [PROD] sessiyalar auth schema'sida (auth.sessions)
SESSION_LIFETIME=120
SESSION_ENCRYPT=true                     # [PROD] sessiya ma'lumotini shifrlash
SESSION_PATH=/
SESSION_COOKIE=xorazm_session            # [PROD] aniq nom (default app-slug'ga tayanmang)
SESSION_DOMAIN=.digital-xorazm.uz        # [PROD] sub-domenlar bo'ylab cookie (nuqta bilan)
SESSION_SECURE_COOKIE=true               # [PROD] faqat HTTPS orqali cookie (TrustProxies bilan)

# ------------------------------------------------------------------------------
# Sanctum + CORS — SPA origin'lari (cookie/CSRF uchun)
# ------------------------------------------------------------------------------
# [PROD] Real frontend sub-domenlari (vergul bilan). localhost QOLDIRMANG.
SANCTUM_STATEFUL_DOMAINS=xbt.digital-xorazm.uz,mahalla.digital-xorazm.uz
FRONTEND_ORIGINS=https://xbt.digital-xorazm.uz,https://mahalla.digital-xorazm.uz

# ------------------------------------------------------------------------------
# Queue / Cache — AI rasm tahlili uchun queue worker MAJBURIY
# ------------------------------------------------------------------------------
QUEUE_CONNECTION=database                # [PROD] worker: php artisan queue:work (supervisor/systemd)
CACHE_STORE=database                     # yoki redis (scale uchun)
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ------------------------------------------------------------------------------
# AI (Anthropic / Claude Vision) — mahalla rasm tahlili
# ------------------------------------------------------------------------------
MAHALLA_AI_DRIVER=claude
ANTHROPIC_API_KEY=                       # [PROD] bo'lmasa AI tahlil doim "pending" qoladi
MAHALLA_AI_MODEL=claude-fable-5          # [PROD] amaldagi model id'sini tasdiqlang
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ------------------------------------------------------------------------------
# Seeder — super-admin boshlang'ich paroli
# ------------------------------------------------------------------------------
ADMIN_SEED_PASSWORD=                     # [PROD] db:seed'dan oldin kuchli parol; keyin almashtiring

# ------------------------------------------------------------------------------
# Redis (ixtiyoriy — prod scale: cache/session/queue)
# ------------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Mail
# ------------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@digital-xorazm.uz"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
